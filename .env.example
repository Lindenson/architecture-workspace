# ============================================================================
#  Architecture Intelligence Platform — environment template
#  Copy to `.env` and fill in real values. `.env` is gitignored.
#  Consumed by: .mcp.json (${VAR} expansion) and docker-compose.
# ============================================================================

# --- Internal auth shared by all AIP MCP servers ---------------------------
# Single bearer token the Claude agent presents to every local MCP server.
AIP_INTERNAL_TOKEN=change-me-internal-token

# --- PostgreSQL (Digital Twin store + pgvector RAG) ------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=architecture_ai
POSTGRES_USER=aip
POSTGRES_PASSWORD=change-me-db-password

# --- Jira (jira-mcp) -------------------------------------------------------
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=change-me-jira-token
JIRA_PROJECT_KEYS=PAY,DOC

# --- GitHub / GitLab (github-mcp) ------------------------------------------
GIT_PROVIDER=github
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=change-me-github-pat
GITHUB_ORG=your-org
# If GitLab instead:
GITLAB_API_URL=https://gitlab.your-org.com/api/v4
GITLAB_TOKEN=change-me-gitlab-pat

# --- SonarQube (sonar-mcp) -------------------------------------------------
SONAR_BASE_URL=https://sonar.your-org.com
SONAR_TOKEN=change-me-sonar-token

# --- Structurizr (structurizr-mcp) -----------------------------------------
STRUCTURIZR_WORKSPACE_PATH=./architecture/c4/workspace.dsl
STRUCTURIZR_API_URL=
STRUCTURIZR_API_KEY=
STRUCTURIZR_API_SECRET=

# --- jQAssistant / Neo4j (jqassistant-mcp) ---------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# --- Wiki / Confluence (wiki-mcp) ------------------------------------------
WIKI_BASE_URL=https://your-org.atlassian.net/wiki
WIKI_EMAIL=you@your-org.com
WIKI_API_TOKEN=change-me-wiki-token
WIKI_SPACE_KEYS=ARCH,DOM

# --- OpenSpec (openspec-mcp) -----------------------------------------------
OPENSPEC_REPO_PATH=../your-product-repo/openspec

# --- Embeddings provider (rag-mcp) -----------------------------------------
# RAG embeddings. Leave EMBEDDINGS_PROVIDER=local to use a local model.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_API_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Server ports (override only on conflicts) -----------------------------
PORT_DIGITAL_TWIN=8080
PORT_JIRA_MCP=8081
PORT_GITHUB_MCP=8082
PORT_SONAR_MCP=8083
PORT_STRUCTURIZR_MCP=8084
PORT_JQASSISTANT_MCP=8085
PORT_WIKI_MCP=8086
PORT_OPENSPEC_MCP=8087
PORT_RAG_MCP=8088
