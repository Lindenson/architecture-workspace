# ============================================================================
#  SECRETS — NEVER COMMIT. All real credentials live in files matched here.
#  The repository ships only *.example templates. See config/README.md.
# ============================================================================

# Environment files (real values)
.env
.env.*
!.env.example

# Local config with real credentials (templates end in .example and ARE committed)
config/*.yml
config/*.yaml
config/*.properties
config/*.json
!config/*.example.yml
!config/*.example.yaml
!config/*.example.properties
!config/*.example.json
!config/README.md

# Spring externalized config imported at runtime (real secrets)
**/application-local.yml
**/application-secret.yml
**/application-*.local.yml

# Tokens / keystores / certs
*.pem
*.p12
*.jks
*.key
*.token
secrets/
**/secrets/

# Claude local settings (may contain machine-specific paths / keys)
.claude/settings.local.json

# ============================================================================
#  Build artifacts — Java / Maven
# ============================================================================
target/
*.class
*.jar
!**/.mvn/wrapper/maven-wrapper.jar
build/
out/
.gradle/

# ============================================================================
#  Generated analysis artifacts (regenerated by the nightly pipeline)
# ============================================================================
jqassistant/scans/*
!jqassistant/scans/.gitkeep
jqassistant/reports/*.html
reports/daily/*
reports/weekly/*
!reports/**/.gitkeep
rag/embeddings/*
!rag/embeddings/.gitkeep
rag/chunks/*
!rag/chunks/.gitkeep
domain/raw/jqa-graph/*
!domain/raw/jqa-graph/.gitkeep

# Neo4j store dump from jQAssistant
*.db
store/

# ============================================================================
#  IDE / OS
# ============================================================================
.idea/
*.iml
.vscode/
*.swp
.DS_Store
Thumbs.db
